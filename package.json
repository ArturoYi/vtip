{
  "name": "vtip-edit",
  "version": "1.0.1",
  "description": "VtipEdit — lightweight Vue 3 WYSIWYG rich-text editor built on Tiptap — composable, tree-shakable, and npm-ready.",
  "type": "module",
  "main": "./dist/vtip-edit.cjs",
  "module": "./dist/vtip-edit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vtip-edit.js",
      "require": "./dist/vtip-edit.cjs"
    },
    "./style.css": "./dist/vtip-edit.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "commit": "czg",
    "changelog": "standard-version --skip.commit --skip.tag",
    "changelog:preview": "standard-version --dry-run",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "prepare": "node scripts/prepare-husky.cjs",
    "commitlint": "commitlint --edit"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArturoYi/vtip-edit.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-3",
    "tiptap",
    "tiptap-editor",
    "editor",
    "rich-text",
    "rich-text-editor",
    "richtext",
    "wysiwyg",
    "wysiwyg-editor",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@tiptap/extension-bold": "^3.18.0",
    "@tiptap/extension-bubble-menu": "^3.18.0",
    "@tiptap/extension-bullet-list": "^3.18.0",
    "@tiptap/extension-code-block-lowlight": "^3.18.0",
    "@tiptap/extension-heading": "^3.18.0",
    "@tiptap/extension-highlight": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-italic": "^3.18.0",
    "@tiptap/extension-list": "^3.18.0",
    "@tiptap/extension-list-item": "^3.18.0",
    "@tiptap/extension-mathematics": "^3.18.0",
    "@tiptap/extension-ordered-list": "^3.18.0",
    "@tiptap/extension-paragraph": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-subscript": "^3.18.0",
    "@tiptap/extension-superscript": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/extension-table-cell": "^3.18.0",
    "@tiptap/extension-table-header": "^3.18.0",
    "@tiptap/extension-table-of-contents": "^3.20.0",
    "@tiptap/extension-table-row": "^3.18.0",
    "@tiptap/extension-text-align": "^3.18.0",
    "@tiptap/extension-text-style": "^3.18.0",
    "@tiptap/extension-typography": "^3.18.0",
    "@tiptap/extensions": "^3.18.0",
    "@tiptap/markdown": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@tiptap/suggestion": "^3.18.0",
    "@tiptap/vue-3": "^3.18.0",
    "add": "^2.0.6",
    "lowlight": "^3.3.0",
    "lucide-vue-next": "^0.563.0",
    "pnpm": "^10.28.2",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "cz-git": "^1.12.0",
    "czg": "^1.12.0",
    "husky": "^9.1.7",
    "reka-ui": "^2.8.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.0.0",
    "unocss": "^66.6.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.27",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "reka-ui": "^2.8.0",
    "vue": "^3.0.0"
  },
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
